<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEONORE TIKTOK CONTROLLER"
            android:textColor="@color/neon_cyan"
            android:textSize="20sp"
            android:fontFamily="monospace"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="20dp"
            android:text="@string/leonore_tech_team"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <!-- Accessibility Status Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_accessibility_status"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvAccessibilityStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_inactive"
                    android:textColor="@color/status_off"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_status_inactive" />
            </LinearLayout>

            <Button
                android:id="@+id/btnEnableAccessibility"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_enable_accessibility"
                android:textColor="@color/neon_cyan"
                android:textAllCaps="false"
                android:fontFamily="monospace"
                android:background="@drawable/bg_btn_neon" />
        </LinearLayout>

        <!-- Microphone Status Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_mic_status"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvMicStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_inactive"
                    android:textColor="@color/status_off"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_status_inactive" />
            </LinearLayout>

            <Button
                android:id="@+id/btnToggleVoice"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_start_voice"
                android:textColor="@color/neon_green"
                android:textAllCaps="false"
                android:fontFamily="monospace"
                android:background="@drawable/bg_btn_neon" />

            <TextView
                android:id="@+id/tvVoiceLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/label_voice_log"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:minLines="2" />
        </LinearLayout>

        <!-- Auto Scroll Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_autoscroll"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="monospace" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_interval"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tvIntervalValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="5s"
                    android:textColor="@color/neon_purple"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seekInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="27"
                android:progress="2"
                android:layout_marginTop="4dp" />

            <Button
                android:id="@+id/btnToggleAutoScroll"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/btn_start_service"
                android:textColor="@color/neon_purple"
                android:textAllCaps="false"
                android:fontFamily="monospace"
                android:background="@drawable/bg_btn_neon" />
        </LinearLayout>

        <!-- Manual Controls Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:padding="16dp"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manual Control"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="monospace" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/btnSwipeUp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="@string/swipe_up_action"
                    android:textColor="@color/neon_cyan"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_btn_neon" />

                <Button
                    android:id="@+id/btnSwipeDown"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="@string/swipe_down_action"
                    android:textColor="@color/neon_cyan"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_btn_neon" />
            </LinearLayout>

            <Button
                android:id="@+id/btnLike"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/like_action"
                android:textColor="@color/neon_pink"
                android:textAllCaps="false"
                android:fontFamily="monospace"
                android:background="@drawable/bg_btn_neon" />
        </LinearLayout>

        <!-- Gesture Control Placeholder Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_panel"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_gesture"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Basic placeholder — tap tombol di bawah untuk simulasi gesture. Versi penuh (kamera + MediaPipe) menyusul."
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/btnGesturePlaceholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Simulate Gesture Trigger"
                android:textColor="@color/neon_green"
                android:textAllCaps="false"
                android:fontFamily="monospace"
                android:background="@drawable/bg_btn_neon" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
