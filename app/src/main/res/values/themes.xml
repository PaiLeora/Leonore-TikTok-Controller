        <item name="colorPrimaryVariant">@color/neon_purple</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/neon_green</item>
        <item name="colorSecondaryVariant">@color/neon_pink</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">@color/cyber_black_dark</item>
        <item name="android:windowBackground">@color/cyber_black</item>
